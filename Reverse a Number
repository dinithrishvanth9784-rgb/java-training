import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
           int r; 
        Scanner s = new Scanner (System.in);
        int N =s.nextInt();
        r=0;
        while (N >0)  {
            int digit =N%10;
              r = r*10+digit;
            N = N /10;
        }
        System.out.print(r);
    }
}
