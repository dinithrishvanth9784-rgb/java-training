import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int i,j;
       // int count;
        Scanner s=new Scanner(System.in);
        int a=s.nextInt();
        for(i=1;i<=a;i++)
        {
             for(j=1;j<=i;j++)
             {  System.out.print("*");
             }
            System.out.println();
           
        }
    }
}
