import java.util.*;
 public class main {
     public static void main(String[]args)
     {
         Scanner s=new Scanner(System.in);
         int i,j;
         int d=s.nextInt();
         for (i=1;i<=d;i++){
            for(j=1;j<=i;j++)
            {
                System.out.print(i);
            }
            System.out.println();
         }
     }
 }
