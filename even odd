import java.util.*;
class Main {
    public static void main(String[] args) {
        
        Scanner s=new Scanner(System.in);
  
        int n=s.nextInt();
        int i;
        int even=0;
        int odd=0;
        for(i=1;i<=n;i++)
        {
            if(i%2==0)
            {
                even=even+i;
              
            }
            else
            {
                odd=odd+i;
            }

        }
        System.out.println("sum of even"+ even);
        System.out.println("sum od odd"+ odd);

    }
}
