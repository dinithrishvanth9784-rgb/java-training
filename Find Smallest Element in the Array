import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner s=new Scanner(System.in);
  
        int n=s.nextInt();
        int i;
       
        int[] a =new int[50];
        for(i=0;i<n;i++) {
        a[i]=s.nextInt();
        }
        int temp=a[0];
        for(i=1;i<n;i++)
        {
            if(temp>a[i])
            {
                temp=a[i];
            }
            
      }
        System.out.println(temp);
    }
}
